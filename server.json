{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.usefolklore/folklore",
  "description": "P2P agent memory: peers share their research so you start from what the network knows, not zero.",
  "title": "Folklore",
  "websiteUrl": "https://usefolklore.sh",
  "repository": {
    "url": "https://github.com/usefolklore/folklore",
    "source": "github"
  },
  "version": "5.0.0",
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "@usefolklore/folklore",
      "version": "5.0.0",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [
        { "type": "positional", "value": "mcp" },
        { "type": "positional", "value": "start" }
      ]
    }
  ]
}
