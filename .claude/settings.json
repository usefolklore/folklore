{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Glob|Grep|Read|WebSearch|WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'exec sh \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/folklore-smart-hook.sh\"'",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "mcp__folklore__.*",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'exec node \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/folklore-mcp-pre.cjs\"'",
            "timeout": 3000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "WebSearch|WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'exec sh \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/folklore-post-fetch.sh\"'",
            "timeout": 10000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'exec node \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/folklore-prompt-submit.cjs\"'",
            "timeout": 5000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'CLAUDE_HOOK_EVENT=SessionStart exec sh \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/folklore-hook.sh\"'",
            "timeout": 5000
          }
        ]
      }
    ],
    "SessionEnd": [],
    "Stop": [],
    "PreCompact": [],
    "SubagentStart": [],
    "SubagentStop": [],
    "Notification": []
  },
  "statusLine": {
    "type": "command",
    "command": "sh -c 'node \"${CLAUDE_PROJECT_DIR:-.}/.claude/helpers/ak-statusline.cjs\" 2>/dev/null'"
  },
  "permissions": {
    "allow": [],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  },
  "env": {
    "FOLKLORE_ENERGY_GATE": "1",
    "FOLKLORE_QUERY_REUSE": "1",
    "FOLKLORE_DENY_WEBSEARCH": "1",
    "FOLKLORE_PREFETCH_PEERS": "0"
  }
}
