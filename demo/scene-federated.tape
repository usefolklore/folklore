# akashik — natural Claude Code session, federated retrieval live.
# Driven by demo/scene-federated.sh. Output: demo/scene-federated.gif

Output demo/scene-federated.gif

Set Shell "zsh"
Set FontSize 13
Set Width 1440
Set Height 900
Set TypingSpeed 26ms
Set PlaybackSpeed 1.0
Set Theme "Catppuccin Mocha"
Set Padding 20
Set Margin 0
Set BorderRadius 10
Set WindowBar Colorful
Set WindowBarSize 30

Hide
Type "cd /Users/saharbarak/personal/akashik"
Enter
Type "export AKASHIK_HOME=$HOME/.akashik.demo"
Enter
Type "export AKASHIK_PREFETCH_TIMEOUT_MS=15000"
Enter
Type "clear"
Enter
Sleep 200ms
Show

Type "claude --permission-mode bypassPermissions --mcp-config /tmp/demo-mcp.json --strict-mcp-config"
Enter
Sleep 9000ms

Type "I'm building a hydrogen leak detection AI. What open-source tools, models, and best practices should I look at?"
Sleep 600ms
Enter
Sleep 75000ms

Type "Which Hugging Face model would you start with for spectroscopy classification?"
Sleep 600ms
Enter
Sleep 55000ms
