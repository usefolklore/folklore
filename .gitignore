# dependencies
node_modules/

# build output
dist/
*.tsbuildinfo
docs/comps/

# logs
*.log
npm-debug.log*

# env
.env
.env.*
!.env.example

# folklore runtime state — per-user, never commit
.folklore/

# vector store
vectors.db
vectors.db-*

# python venv for graphify sidecar (Phase 1)
vendor/graphify/.venv/
__pycache__/
*.pyc
*.pyo

# editors / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# local agent state — never commit (contains provider tokens, transient session IDs)
.claude-octopus/
.agents/
.claude-plugin/
# …except the plugin manifest — it ships in the npm package (see package.json "files")
!.claude-plugin/plugin.json

# editor / IDE drafts and backups
*.bak
*.bak.*
findings.md

# Private Fellows-application strategy (never publish - lives in public docs/ dir)
docs/FELLOWS-RESTEER.md
docs/FELLOWS-EVAL-SPEC.md
docs/FELLOWS-FRAMING.md
docs/FELLOWS-NARRATIVE.md
docs/HANDOVER.md
# Fellows eval — private differentiator until submission; un-ignore at submit
scripts/fellows-eval/
# Ignore eval working data, but keep the directory traversable so the
# committed retrieval-quality fixtures below can be un-ignored.
eval/*
# ...except committed retrieval-quality fixtures used by bench/ runners.
!eval/fixtures/

# folklore demo build artifact
examples/deny-gate/.demo-home/

# folklore federation demo homes (build artifacts; the .gif is committed)
examples/federation/.alice-home/
examples/federation/.bob-home/

# folklore network demo build artifacts (the .gif is committed)
examples/network/.alice-home/
examples/network/.bob-home/
examples/network/.tracker.pid
examples/network/.tracker.log

# in-session demo build artifacts (the .gif is committed)
examples/in-session/.frames/
examples/in-session/.you-home/
examples/in-session/.peer-*/

# live-feed demo build artifacts (the .gif is committed)
examples/live-feed/.you/
examples/live-feed/.peer-*/
examples/live-feed/.real-events.jsonl
client/menubar-macos/build/

# direnv secrets
.envrc.local
